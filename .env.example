# Standalone web UI login
MAIL_ASSISTANT_WEB_USER=admin
MAIL_ASSISTANT_WEB_PASSWORD=change-me
MAIL_ASSISTANT_TIMEZONE=Europe/Stockholm

# Tools API connection
MAIL_ASSISTANT_TOOLS_BASE_URL=https://tools.tornevall.net/api
MAIL_ASSISTANT_TOOLS_TOKEN=
MAIL_ASSISTANT_TOOLS_MAIL_TOKEN=
MAIL_ASSISTANT_AI_MODEL=gpt-5.4
MAIL_ASSISTANT_AI_FALLBACK_MODEL=o4
MAIL_ASSISTANT_AI_REASONING_EFFORT=medium

# Reply transport: smtp | pickup | php_mail | custom_mta | tools_api
MAIL_ASSISTANT_MAIL_TRANSPORT=smtp
# Optional ordered fallback chain, comma-separated. Example: smtp,tools_api,pickup
MAIL_ASSISTANT_MAIL_FALLBACK_TRANSPORTS=
MAIL_ASSISTANT_MAIL_FALLBACK_TOOLS_API=true

# custom_mta: full command that reads RFC 2822 message on stdin (e.g. /usr/lib/postfix/postdrop -r)
MAIL_ASSISTANT_MTA_COMMAND=

# pickup: write message file to MTA spool/pickup directory (e.g. /var/spool/postfix/maildrop)
MAIL_ASSISTANT_PICKUP_DIR=

MAIL_ASSISTANT_SMTP_HOST=smtp.example.com
MAIL_ASSISTANT_SMTP_PORT=587
MAIL_ASSISTANT_SMTP_USERNAME=
MAIL_ASSISTANT_SMTP_PASSWORD=
# Optional overrides; defaults are tls, host-name EHLO, and From-header envelope sender
MAIL_ASSISTANT_SMTP_SECURITY=
MAIL_ASSISTANT_SMTP_EHLO=
MAIL_ASSISTANT_SMTP_TIMEOUT=20
MAIL_ASSISTANT_SMTP_FROM_ENVELOPE=

# Optional web UI hints
MAIL_ASSISTANT_TOOLS_ADMIN_URL=https://tools.tornevall.net/admin/mail-support-assistant
MAIL_ASSISTANT_TITLE=Mail Support Assistant

