#!/usr/bin/php
<?php

require_once __DIR__ . DIRECTORY_SEPARATOR . 'src' . DIRECTORY_SEPARATOR . 'bootstrap.php';

use MailSupportAssistant\Runner\MailAssistantRunner;
use MailSupportAssistant\Support\Logger;
use MailSupportAssistant\Tools\ToolsApiClient;

$options = [
    'dry_run' => false,
    'limit' => null,
    'mailbox' => null,
    'self_test' => false,
    'cleanup' => false,
    'cleanup_copies' => false,
    'include_history' => false,
    'help' => false,
];

foreach (array_slice($argv, 1) as $argument) {
    $argument = trim((string) $argument);
    if ($argument === '--help' || $argument === '-h') {
        $options['help'] = true;
        continue;
    }
    if ($argument === '--self-test') {
        $options['self_test'] = true;
        continue;
    }
    if ($argument === '--dry-run' || $argument === 'dry-run' || $argument === 'dry') {
        $options['dry_run'] = true;
        continue;
    }
    if ($argument === '--cleanup') {
        $options['cleanup'] = true;
        continue;
    }
    if ($argument === '--cleanup-copies') {
        $options['cleanup'] = true;
        $options['cleanup_copies'] = true;
        continue;
    }
    if ($argument === '--include-history') {
        $options['include_history'] = true;
        continue;
    }
    if (strpos($argument, '--limit=') === 0) {
        $options['limit'] = (int) substr($argument, 8);
        continue;
    }
    if (strpos($argument, '--mailbox=') === 0) {
        $options['mailbox'] = (int) substr($argument, 10);
        continue;
    }
}

if ($options['help']) {
    echo "Tornevall Tools Mail Assistant\n";
    echo "Usage:\n";
    echo "  php run --help\n";
    echo "  php run --self-test\n";
    echo "  php run --dry-run [--limit=5] [--mailbox=12] [--include-history]\n";
    echo "  php run --cleanup              Purge log, last-run and message state\n";
    echo "  php run --cleanup-copies       Same + delete saved message copies\n";
    echo "\nEnv keys:\n";
    echo "  MAIL_ASSISTANT_TOOLS_BASE_URL\n";
    echo "  MAIL_ASSISTANT_TOOLS_TOKEN\n";
    echo "  MAIL_ASSISTANT_TOOLS_MAIL_TOKEN\n";
    echo "  MAIL_ASSISTANT_CLI_PROGRESS\n";
    echo "  MAIL_ASSISTANT_INCLUDE_CASE_LINK\n";
    echo "  MAIL_ASSISTANT_UNANSWERED_REPORT_ENABLED / MAIL_ASSISTANT_UNANSWERED_REPORT_TO\n";
    echo "  MAIL_ASSISTANT_MAIL_TRANSPORT (smtp|php_mail|custom_mta|tools_api)\n";
    echo "  MAIL_ASSISTANT_SMTP_HOST / MAIL_ASSISTANT_SMTP_PORT / MAIL_ASSISTANT_SMTP_SECURITY\n";
    echo "  MAIL_ASSISTANT_SMTP_USERNAME / MAIL_ASSISTANT_SMTP_PASSWORD\n";
    echo "  MAIL_ASSISTANT_SMTP_EHLO / MAIL_ASSISTANT_SMTP_TIMEOUT / MAIL_ASSISTANT_SMTP_FROM_ENVELOPE\n";
    echo "  MAIL_ASSISTANT_MAIL_FALLBACK_TOOLS_API / MAIL_ASSISTANT_MTA_COMMAND\n";
    echo "  MAIL_ASSISTANT_SUBJECT_ISSUE_ID_ENABLED / MAIL_ASSISTANT_SUBJECT_ISSUE_LABEL\n";
    echo "  MAIL_ASSISTANT_SUBJECT_ISSUE_PREFIX / MAIL_ASSISTANT_SUBJECT_ISSUE_LENGTH\n";
    echo "  MAIL_ASSISTANT_CRON_LOCK_DIR (used by cron-run.sh PID lock)\n";
    echo "  MAIL_ASSISTANT_WEB_USER\n";
    echo "  MAIL_ASSISTANT_WEB_PASSWORD\n";
    echo "\nNotes:\n";
    echo "  History/message-state diagnostics are hidden by default and only included when --include-history is used.\n";
    echo "  Concurrent run/dry-run executions are skipped automatically while another process holds the run lock.\n";
    echo "  cron-run.sh also keeps its own PID-aware shell lock so overlapping cron invocations can be rejected before PHP starts.\n";
    echo "  Processed message outcomes can now be synced back into Tools as threaded support cases when the Tools token is valid.\n";
    exit(0);
}

$logger = new Logger();
$runner = new MailAssistantRunner(new ToolsApiClient(), $logger);

if ($options['self_test']) {
    $result = $runner->selfTest();
    echo json_encode($result, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) . "\n";
    exit(0);
}

if ($options['cleanup']) {
    $result = $runner->cleanup([
        'log'      => true,
        'last_run' => true,
        'state'    => true,
        'copies'   => $options['cleanup_copies'],
    ]);
    echo json_encode($result, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) . "\n";
    exit(0);
}

$result = $runner->run($options);
echo json_encode($result, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) . "\n";
exit($result['ok'] ? 0 : 1);

